# ==========================================
# BarracaPedidos - PRODUCCIÓN
# ==========================================

# --- Base de Datos ---
POSTGRES_USER=barraca_user
POSTGRES_PASSWORD=generar_password_segura
POSTGRES_DB=barraca
POSTGRES_HOST=postgres.produccion.com
POSTGRES_PORT=5432
DATABASE_URL=postgresql://barraca_user:generar_password_segura@postgres.produccion.com:5432/barraca

# --- Aplicación ---
APP_ENV=production
DEBUG=false
SECRET_KEY=contraseña_segura

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=["https://barraca.com", "https://www.barraca.com"]

# --- URL Base ---
BASE_URL=https://barraca.com

# --- Logging ---
LOG_LEVEL=warning

# --- Admin por defecto (cambiar después del primer login)---
DEFAULT_ADMIN_PASSWORD=AdminTemp123456!
