# ==========================================
# BarracaPedidos - Configuracion
# ==========================================
# COPIAR este archivo a .env y completar los valores reales.
# NUNCA commitear .env con valores reales.
#
# Para desarrollo: cp .env.example .env
# Para produccion: editar los valores con credenciales reales.
# ==========================================

# --- Base de Datos (OBLIGATORIO) ---
POSTGRES_USER=barraca_user
POSTGRES_PASSWORD=<CAMBIAR_POR_UN_PASSWORD_FUERTE>
POSTGRES_DB=barraca

# --- Aplicacion ---
APP_ENV=development
DEBUG=true
SECRET_KEY=<GENERAR_CON_openssl_rand_hex_32>

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- URL Base (OBLIGATORIO en produccion) ---
# Desarrollo: http://localhost:8000
# Produccion: https://pedidos-generales.loquinto.com
BASE_URL=http://localhost:8000

# --- Email (Resend API) ---
RESEND_API_KEY=<TU_RESEND_API_KEY>
RESEND_FROM_EMAIL=pedidos@loquinto.com

# --- Swagger Protection (opcional) ---
# SWAGGER_PASSWORD=<PASSWORD_PARA_SWAGGER>

# --- Pool de conexiones (opcional) ---
# DATABASE_POOL_SIZE=20
# DATABASE_MAX_OVERFLOW=10